# Optional: public URL for Settings → Privacy Policy (defaults in constants/legal.ts)
# EXPO_PUBLIC_PRIVACY_POLICY_URL=https://youruser.github.io/your-repo/privacy/

# AdMob: use real unit IDs only when set to 1 (e.g. App Store / EAS production). Omit for local & TestFlight testing with Google sample ads.
# EXPO_PUBLIC_ADMOB_USE_PRODUCTION_UNITS=1

# Physical device: paste test device ID(s) from Xcode console (comma-separated). Improves fill with production units and some devices with sample units.
# EXPO_PUBLIC_ADMOB_TEST_DEVICE_IDS=ff3054ee1c665c4ab48b898d088978d1
